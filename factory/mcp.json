{
  "mcpServers": {
    "augment-context-engine": {
      "type": "stdio",
      "command": "auggie",
      "args": [
        "--mcp",
        "--mcp-auto-workspace"
      ],
      "disabled": false
    },
    "seek": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@manuelvanrijn/seek-mcp-server@0.1.2"
      ]
    }
  }
}
