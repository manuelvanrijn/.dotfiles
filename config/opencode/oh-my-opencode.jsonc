{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": false
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "agents": {
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.6",
      "prompt_append": "Do not create Git worktrees or switch branches automatically. Assume the user manages worktrees. Ask before performing any worktree-related Git actions."
    },
    "hephaestus": {
      // builder deep agent
      // "model": "openai/gpt-5.3-codex",
      // "variant": "medium"
      // "model": "openai/gpt-5.4",
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "librarian": {
      // "model": "github-copilot/claude-sonnet-4.6"
      "model": "github-copilot/gemini-3-flash-preview"
    },
    "explore": {
      "model": "github-copilot/grok-code-fast-1"
      // "model": "github-copilot/claude-haiku-4.5"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash-preview"
    },
    "prometheus": {
      // planner
      "model": "github-copilot/gpt-5.4"
      // "model": "github-copilot/claude-opus-4.6"
    },
    "metis": {
      // consultant
      "model": "github-copilot/gpt-5.4"
      // "model": "github-copilot/claude-opus-4.6"
    },
    "momus": {
      // plan reviewer
      // "model": "github-copilot/gpt-5.4",
      // "variant": "high"
      "model": "github-copilot/claude-opus-4.6"
    },
    "atlas": {
      // orchestrator
      // "model": "github-copilot/gpt-5.4",
      "model": "github-copilot/claude-sonnet-4.6",
      "prompt_append": "Do not create Git worktrees or switch branches automatically. Assume the user manages worktrees. Ask before performing any worktree-related Git actions."
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3.1-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-sonnet-4.6"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  },
  "disabled_hooks": [
    "think-mode"
  ]
}
