{
  "sound": true,
  "notification": true,
  "timeout": 5,
  "showProjectName": true,
  "showSessionTitle": false,
  "showIcon": true,
  "suppressWhenFocused": true,
  "notificationSystem": "node-notifier",
  "events": {
    "permission": {
      "sound": true,
      "notification": true
    },
    "complete": {
      "sound": true,
      "notification": true
    },
    "subagent_complete": {
      "sound": false,
      "notification": false
    },
    "error": {
      "sound": true,
      "notification": true
    },
    "question": {
      "sound": true,
      "notification": true
    },
    "user_cancelled": {
      "sound": false,
      "notification": false
    }
  }
}
