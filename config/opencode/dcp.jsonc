{
  "$schema": "https://raw.githubusercontent.com/Opencode-DCP/opencode-dynamic-context-pruning/master/dcp.schema.json",
  "enabled": false, // a bit to experimental for me for now
  "experimental": {
    "allowSubAgents": true
  },
  "compress": {
    "maxContextLimit": "80%",
    "minContextLimit": "30%"
  }
}
