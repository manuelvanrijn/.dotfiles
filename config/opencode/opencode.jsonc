{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5-mini",
  "autoupdate": true,
  "username": "Manuel",
  "instructions": [
    "CLAUDE.md",
    ".cursor/rules/*.md",
    ".github/instructions/*.md",
    "GEMINI.md",
    "WINDSURF.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "agent": {
    "build": {
      "mode": "primary"
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "mode": "subagent",
      "prompt": "{file:./prompts/explore.txt}"
    }
  },
  "plugin": [
    "opencode-openai-codex-auth@4.4.0",
    "@mohak34/opencode-notifier@latest",
    "@tarquinen/opencode-dcp@latest"
  ],
  "permission": {
    "agent-browser*": "allow",
    "augment-context-engine*": "allow",
    "brave-search*": "allow",
    "external_directory": {
      "/private/tmp/**": "allow",
      "/tmp/**": "allow",
      "/Users/manuel/.local/share/mise/installs/**": "allow"
    }
  },
  "mcp": {
    "augment-context-engine": {
      "type": "local",
      "command": [
        "auggie",
        "--mcp",
        "--mcp-auto-workspace"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "mms",
        "--memory",
        "{env:PWD}/.opencode/memory.db"
      ]
    },
    "mcp_vector_search": {
      "type": "local",
      "command": [
        "mcp-vector-search",
        "mcp"
      ],
      "environment": {
        "MCP_ENABLE_FILE_WATCHING": "false"
      },
      "timeout": 60000
    }
  },
  "provider": {
    "github-cp": {
      "name": "Copilot",
      "options": {
        "baseURL": "http://localhost:8317/v1",
        "api_key": "dummy-not-used"
      },
      "models": {
        "gpt-4.1": {
          "name": "GPT 4.1 [FREE]"
        },
        "gpt-4o": {
          "name": "GPT 4o [FREE]"
        },
        "gpt-5": {
          "name": "GPT 5"
        },
        "gpt-5-mini": {
          "name": "GPT 5 mini [FREE]"
        },
        "claude-opus-4.6": {
          "name": "Opus 4.6"
        },
        "claude-sonnet-4.6": {
          "name": "Sonnet 4.6"
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro"
        }
      }
    }
  }
}
