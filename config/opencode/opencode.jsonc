{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5-mini",
  "autoupdate": true,
  "username": "Manuel",
  "instructions": [
    "CLAUDE.md",
    ".cursor/rules/*.md",
    ".github/instructions/*.md",
    "GEMINI.md",
    "WINDSURF.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true
  },
  "default_agent": "builder", // enable for oh-my-opencode
  "agent": {
    "builder": {
      "mode": "primary",
      "description": "Build",
      "name": "builder"
    },
    "explore": {
      "mode": "subagent",
      //"model": "github-copilot/gpt-5-mini", // best free default
      //"model": "github-copilot/gpt-5-mini", // fastest free
      //"model": "openai/ gpt-5.1-codex-mini", // more complex code tracing
      "prompt": "{file:./prompts/explore.txt}",
      "disable": true
    },
    "general": {
      "mode": "subagent",
      // "model": "github-copilot/claude-sonnet-4.5",
      // "model": "openai/gpt-5.2"
      //"model": "github-copilot/gpt-5-mini", // fastest free
      "disable": true
    }
  },
  "plugin": [
    "opencode-openai-codex-auth@4.4.0",
    "oh-my-opencode@latest"
  ],
  "permission": {
    "agent-browser*": "allow",
    "augment-context-engine*": "allow",
    "brave-search*": "allow",
    "external_directory": {
      "/Users/manuel/.local/share/mise/installs/**": "allow"
    }
  },
  "mcp": {
    "augment-context-engine": {
      "type": "local",
      "command": [
        "auggie",
        "--mcp",
        "--mcp-auto-workspace"
      ]
    }
  },
  "provider": {
    "github-cp": {
      "name": "Copilot",
      "options": {
        "baseURL": "http://localhost:8317/v1",
        "api_key": "dummy-not-used"
      },
      "models": {
        "gpt-4.1": {
          "name": "GPT 4.1 [FREE]"
        },
        "gpt-4o": {
          "name": "GPT 4o [FREE]"
        },
        "gpt-5": {
          "name": "GPT 5"
        },
        "gpt-5-mini": {
          "name": "GPT 5 mini [FREE]"
        },
        "claude-opus-4.6": {
          "name": "Opus 4.6"
        },
        "claude-sonnet-4.6": {
          "name": "Sonnet 4.6"
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro"
        }
      }
    }
  }
}
